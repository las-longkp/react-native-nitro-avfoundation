{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitroavfoundation"],
  "ios": {
    "iosModuleName": "NitroAvfoundation"
  },
  "android": {
    "androidNamespace": ["nitroavfoundation"],
    "androidCxxLibName": "NitroAvfoundation"
  },
  "autolinking": {
    "AudioPlayer": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridAudioPlayer"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
